@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-header">
    <div>
        <h1><i class="bi bi-speedometer2"></i> Dashboard</h1>
        <p>PhoneShop Management System overview</p>
    </div>
</div>

<div class="stats-grid">
    <div class="stat-card phones">
        <div class="stat-icon"><i class="bi bi-phone"></i></div>
        <div class="stat-value">20</div>
        <div class="stat-label">Total Phones</div>
    </div>
    <div class="stat-card users">
        <div class="stat-icon"><i class="bi bi-people"></i></div>
        <div class="stat-value">1</div>
        <div class="stat-label">Users</div>
    </div>
    <div class="stat-card pending">
        <div class="stat-icon"><i class="bi bi-hourglass-split"></i></div>
        <div class="stat-value">20</div>
        <div class="stat-label">Pending Review</div>
    </div>
    <div class="stat-card approved">
        <div class="stat-icon"><i class="bi bi-check-circle"></i></div>
        <div class="stat-value">0</div>
        <div class="stat-label">Approved</div>
    </div>
</div>

<div class="card-custom" style="padding:32px;text-align:center;">
    <div style="width:72px;height:72px;margin:0 auto 16px;background:var(--primary-light);border-radius:50%;display:flex;align-items:center;justify-content:center;">
        <i class="bi bi-phone" style="font-size:2rem;color:var(--primary);"></i>
    </div>
    <h3 style="font-weight:700;color:var(--gray-900);margin-bottom:8px;">PhoneShop Management System</h3>
    <p style="color:var(--gray-500);max-width:480px;margin:0 auto;">
        A full-featured phone inventory management application built with ASP.NET Core,
        featuring N-Layer architecture, JWT authentication, and multiple design patterns.
    </p>
    <div class="d-flex justify-content-center gap-3 mt-4 flex-wrap">
        <a asp-controller="Phones" asp-action="Index" class="btn-primary-custom">
            <i class="bi bi-phone"></i> Manage Phones
        </a>
        <a asp-controller="Users" asp-action="Index" class="btn-outline-custom">
            <i class="bi bi-people"></i> Manage Users
        </a>
    </div>
</div>
