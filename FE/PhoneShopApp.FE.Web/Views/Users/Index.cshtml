@model List<PhoneShopApp.FE.Web.Models.Users.UserViewModel>
@{
    ViewData["Title"] = "User Management";
}

<div class="page-header">
    <div>
        <h1><i class="bi bi-people"></i> User Management</h1>
        <p>Manage system users and their roles</p>
    </div>
    <button class="btn-primary-custom" data-bs-toggle="modal" data-bs-target="#addUserModal">
        <i class="bi bi-person-plus"></i> Add New User
    </button>
</div>

<div class="table-container">
    <table class="table-modern">
        <thead>
            <tr>
                <th>ID</th>
                <th>Username</th>
                <th>Full Name</th>
                <th>Role</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="4">
                        <div class="empty-state">
                            <div class="empty-icon">
                                <i class="bi bi-person-x"></i>
                            </div>
                            <h3>No users found</h3>
                            <p>Add your first user to get started.</p>
                        </div>
                    </td>
                </tr>
            }
            else
            {
                foreach (var user in Model)
                {
                    <tr>
                        <td><span style="color:var(--gray-400);font-weight:600;">#@user.Id</span></td>
                        <td>
                            <i class="bi bi-person-circle text-muted"></i>
                            <strong>@user.Username</strong>
                        </td>
                        <td>@user.FullName</td>
                        <td>
                            @if (user.Role == "Admin")
                            {
                                <span class="badge-role badge-admin">Admin</span>
                            }
                            else
                            {
                                <span class="badge-role badge-member">Member</span>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@* ── Add User Modal ── *@
<div class="modal fade modal-custom" id="addUserModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-person-plus"></i> Create New User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Create" method="post">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label-custom">Username</label>
                        <input name="Username" class="form-control-custom" placeholder="Enter username" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label-custom">Full Name</label>
                        <input name="FullName" class="form-control-custom" placeholder="Enter full name" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label-custom">Password</label>
                        <input name="Password" type="password" class="form-control-custom" placeholder="Enter password" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label-custom">Role</label>
                        <select name="Role" class="form-select-custom">
                            <option value="Member">Member</option>
                            <option value="Admin">Admin</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-outline-custom" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-primary-custom">Save User</button>
                </div>
            </form>
        </div>
    </div>
</div>
