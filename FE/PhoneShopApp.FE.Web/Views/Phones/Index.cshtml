@model List<PhoneShopApp.FE.Web.Models.Phones.PhoneViewModel>
@{
    ViewData["Title"] = "Phones";
    var keyword = ViewData["Keyword"] as string;
    var searchBy = ViewData["SearchBy"] as string;
}

<div class="page-header">
    <div>
        <h1><i class="bi bi-phone"></i> Phone Inventory</h1>
        <p>@Model.Count phones from the Backend API</p>
    </div>
    <div class="d-flex gap-2 align-items-center">
        <span class="text-muted small">@Model.Count total</span>
        <form asp-controller="Auth" asp-action="Logout" method="post" style="display:inline;">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn-outline-custom" style="padding:6px 14px;font-size:0.8125rem;">
                <i class="bi bi-box-arrow-right"></i> Logout
            </button>
        </form>
    </div>
</div>

@* ── Search Bar ── *@
<form method="get" class="search-bar">
    <div class="row">
        <div class="search-input-wrap">
            <label class="form-label-custom">Search phones</label>
            <input type="text" name="keyword" value="@keyword" class="form-control-custom" placeholder="Search model, brand, or specs..." />
        </div>
        <div class="search-select-wrap">
            <label class="form-label-custom">Filter by</label>
            <select name="searchBy" class="form-select-custom">
                <option value="" selected="@(string.IsNullOrWhiteSpace(searchBy))">All fields</option>
                <option value="model" selected="@(searchBy == "model")">Model</option>
                <option value="brand" selected="@(searchBy == "brand")">Brand</option>
            </select>
        </div>
        <div class="search-btn-wrap">
            <label class="form-label-custom">&nbsp;</label>
            <button type="submit" class="btn-primary-custom">
                <i class="bi bi-search"></i> Search
            </button>
        </div>
    </div>
</form>

@if (Model.Count == 0)
{
    <div class="empty-state card-custom">
        <div class="empty-icon">
            <i class="bi bi-inbox"></i>
        </div>
        <h3>No phones found</h3>
        <p>Try adjusting your search criteria or add new phones to the inventory.</p>
    </div>
}
else
{
    @* ── Card Grid ── *@
    <div class="phone-card-grid">
        @foreach (var item in Model)
        {
            var brandClass = "brand-default";
            var brandLower = item.Brand?.ToLowerInvariant() ?? "";
            if (brandLower.Contains("apple")) brandClass = "brand-apple";
            else if (brandLower.Contains("samsung")) brandClass = "brand-samsung";
            else if (brandLower.Contains("google")) brandClass = "brand-google";
            else if (brandLower.Contains("xiaomi") || brandLower.Contains("redmi")) brandClass = "brand-xiaomi";
            else if (brandLower.Contains("oneplus")) brandClass = "brand-oneplus";
            else if (brandLower.Contains("sony")) brandClass = "brand-sony";
            else if (brandLower.Contains("asus") || brandLower.Contains("rog")) brandClass = "brand-asus";
            else if (brandLower.Contains("nothing")) brandClass = "brand-nothing";
            else if (brandLower.Contains("oppo")) brandClass = "brand-oppo";
            else if (brandLower.Contains("vivo")) brandClass = "brand-vivo";
            else if (brandLower.Contains("huawei")) brandClass = "brand-huawei";
            else if (brandLower.Contains("motorola")) brandClass = "brand-motorola";
            else if (brandLower.Contains("honor")) brandClass = "brand-honor";

            var brandIcon = "bi bi-phone";
            if (brandLower.Contains("apple")) brandIcon = "bi bi-apple";
            else if (brandLower.Contains("samsung") || brandLower.Contains("galaxy")) brandIcon = "bi bi-phone-flip";
            else if (brandLower.Contains("google") || brandLower.Contains("pixel")) brandIcon = "bi bi-google";
            else if (brandLower.Contains("asus") || brandLower.Contains("rog")) brandIcon = "bi bi-cpu";
            else if (brandLower.Contains("nothing")) brandIcon = "bi bi-lightning";

            var statusClass = item.Status?.ToLowerInvariant() switch
            {
                "approved" => "badge-approved",
                "rejected" => "badge-rejected",
                _ => "badge-pending"
            };

            <div class="phone-card">
                <div class="phone-card-header">
                    <div class="phone-card-icon @brandClass">
                        <i class="@brandIcon"></i>
                    </div>
                    <span class="badge-status @statusClass">@item.Status</span>
                </div>
                <div class="phone-card-body">
                    <h3>@item.Model</h3>
                    <span class="brand-name"><i class="bi bi-building"></i> @item.Brand</span>
                </div>
                <div class="phone-card-specs">
                    <span class="spec-label">Specs:</span> @(string.IsNullOrWhiteSpace(item.Specifications) ? "—" : item.Specifications)
                </div>
                <div class="phone-card-footer">
                    <span class="text-muted" style="font-size:0.75rem;">ID: @item.Id</span>
                    <div class="phone-card-actions">
                        <button class="btn-icon btn-icon-edit" title="Edit" data-bs-toggle="modal" data-bs-target="#editPhoneModal-@item.Id">
                            <i class="bi bi-pencil"></i>
                        </button>
                        <form asp-action="Delete" method="post" style="display:inline;" onsubmit="return confirm('Delete this phone?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="btn-icon btn-icon-delete" title="Delete">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                        @if (item.Status == "Pending")
                        {
                            <form asp-action="UpdateStatus" method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <input type="hidden" name="status" value="Approved" />
                                <button type="submit" class="btn-icon btn-icon-approve" title="Approve">
                                    <i class="bi bi-check-lg"></i>
                                </button>
                            </form>
                            <form asp-action="UpdateStatus" method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <input type="hidden" name="status" value="Rejected" />
                                <button type="submit" class="btn-icon btn-icon-reject" title="Reject">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>

            @* ── Edit Modal ── *@
            <div class="modal fade modal-custom" id="editPhoneModal-@item.Id" tabindex="-1">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Edit Phone #@item.Id</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <form asp-action="Edit" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="Id" value="@item.Id" />
                            <div class="modal-body">
                                <div class="mb-3">
                                    <label class="form-label-custom">Model</label>
                                    <input name="Model" class="form-control-custom" value="@item.Model" required />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label-custom">Brand</label>
                                    <input name="Brand" class="form-control-custom" value="@item.Brand" required />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label-custom">Specifications</label>
                                    <textarea name="Specifications" class="form-control-custom" rows="3">@item.Specifications</textarea>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn-outline-custom" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn-primary-custom">Save changes</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>

    @* ── Add Phone Floating Button ── *@
    <button class="btn-primary-custom" style="position:fixed;bottom:32px;right:32px;width:56px;height:56px;border-radius:50%;padding:0;justify-content:center;box-shadow:var(--shadow-lg);z-index:50;"
            data-bs-toggle="modal" data-bs-target="#addPhoneModal" title="Add new phone">
        <i class="bi bi-plus-lg" style="font-size:1.5rem;"></i>
    </button>

    @* ── Add Phone Modal ── *@
    <div class="modal fade modal-custom" id="addPhoneModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add New Phone</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label-custom">Model</label>
                            <input name="Model" class="form-control-custom" placeholder="e.g. iPhone 15 Pro Max" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label-custom">Brand</label>
                            <input name="Brand" class="form-control-custom" placeholder="e.g. Apple" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label-custom">Specifications</label>
                            <textarea name="Specifications" class="form-control-custom" rows="3" placeholder="CPU, RAM, storage, features..."></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn-outline-custom" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn-primary-custom">Add Phone</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
