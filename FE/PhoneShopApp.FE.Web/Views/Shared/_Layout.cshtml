<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PhoneShop</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PhoneShopApp.FE.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="main-header">
        <div class="container py-3 d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-4">
                <a class="brand" asp-controller="Phones" asp-action="Index">
                    <span>PhoneShop</span>
                </a>
                <nav class="d-flex gap-2">
                    <a class="nav-link-custom" asp-controller="Phones" asp-action="Index">
                        <i class="bi bi-phone"></i> Phones
                    </a>
                    <a class="nav-link-custom" asp-controller="Users" asp-action="Index">
                        <i class="bi bi-people"></i> Users
                    </a>
                </nav>
            </div>
            <span class="text-muted small">MVC Frontend &bull; API Backend</span>
        </div>
    </header>

    <div class="container page-wrap">
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="footer">
        <div class="container py-3 text-center">
            PhoneShop Management System &copy; @DateTime.Now.Year &mdash; ASP.NET Core MVC + Web API
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
